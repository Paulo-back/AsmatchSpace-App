<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/corFundo"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/blue_navy"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/imgFundo"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.12"
        android:scaleType="centerCrop"
        android:src="@drawable/fundo"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ViewFlipper
        android:id="@+id/viewFlipper"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="30dp"
        android:inAnimation="@android:anim/slide_in_left"
        android:outAnimation="@android:anim/slide_out_right"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Passo 0: E-mail -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingTop="60dp"
            android:paddingBottom="40dp">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="72dp"
                android:src="@drawable/logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Recuperar senha"
                android:textColor="@color/white"
                android:textSize="22dp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="24dp"
                android:alpha="0.75"
                android:text="Informe o e-mail cadastrado para continuar."
                android:textAlignment="center"
                android:textColor="@color/white"
                android:textSize="13dp" />

            <TextView
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:text="E-mail"
                android:textColor="@color/white"
                android:textSize="13dp" />

            <EditText
                android:id="@+id/editEmailRecuperacao"
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:background="@drawable/text_box"
                android:hint="yourname@email.com"
                android:inputType="textEmailAddress"
                android:padding="10dp"
                android:textColor="@color/white"
                android:textColorHint="#B3FFFFFF"
                android:textSize="12dp" />

            <Button
                android:id="@+id/btnAvancarEmail"
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:backgroundTint="@color/turquoise_light"
                android:text="CONTINUAR"
                android:textColor="@color/blue_navy"
                android:textSize="14dp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textVoltarLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Voltar ao login"
                android:textColor="@color/turquoise_light"
                android:textSize="13dp" />
        </LinearLayout>

        <!-- Passo 1: Confirmação de identidade -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingTop="60dp"
            android:paddingBottom="40dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Confirmar identidade"
                android:textColor="@color/white"
                android:textSize="22dp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="24dp"
                android:alpha="0.75"
                android:text="Confirme seus dados cadastrados para prosseguir."
                android:textAlignment="center"
                android:textColor="@color/white"
                android:textSize="13dp" />

            <TextView
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:text="Data de nascimento"
                android:textColor="@color/white"
                android:textSize="13dp" />

            <EditText
                android:id="@+id/editDataNascimento"
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:background="@drawable/text_box"
                android:hint="DD/MM/AAAA"
                android:inputType="number"
                android:maxLength="10"
                android:padding="10dp"
                android:textColor="@color/white"
                android:textColorHint="#B3FFFFFF"
                android:textSize="12dp" />

            <!-- CPF — visível só se o usuário tiver CPF cadastrado -->
            <TextView
                android:id="@+id/labelCpf"
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="CPF"
                android:textColor="@color/white"
                android:textSize="13dp"
                android:visibility="gone" />

            <EditText
                android:id="@+id/editCpf"
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:background="@drawable/text_box"
                android:hint="000.000.000-00"
                android:inputType="number"
                android:maxLength="11"
                android:padding="10dp"
                android:textColor="@color/white"
                android:textColorHint="#B3FFFFFF"
                android:textSize="12dp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnConfirmarIdentidade"
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:backgroundTint="@color/turquoise_light"
                android:text="CONFIRMAR"
                android:textColor="@color/blue_navy"
                android:textSize="14dp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textVoltarEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Voltar"
                android:textColor="@color/turquoise_light"
                android:textSize="13dp" />
        </LinearLayout>

        <!-- Passo 2: Nova senha -->
        <!-- Passo 2: Nova senha -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingTop="60dp"
            android:paddingBottom="40dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nova senha"
                android:textColor="@color/white"
                android:textSize="22dp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="24dp"
                android:alpha="0.75"
                android:text="Escolha uma senha forte para sua conta."
                android:textAlignment="center"
                android:textColor="@color/white"
                android:textSize="13dp" />

            <TextView
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:text="Nova senha"
                android:textColor="@color/white"
                android:textSize="13dp" />

            <!-- Nova senha com olhinho -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/containerNovaSenha"
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:background="@drawable/text_box">

                <EditText
                    android:id="@+id/editNovaSenha"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:hint="Mínimo 8 caracteres"
                    android:inputType="textPassword"
                    android:padding="10dp"
                    android:textColor="@color/white"
                    android:textColorHint="#B3FFFFFF"
                    android:textSize="12dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/btnToggleNovaSenha"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageButton
                    android:id="@+id/btnToggleNovaSenha"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="4dp"
                    android:background="@null"
                    android:contentDescription="Mostrar nova senha"
                    android:padding="6dp"
                    android:src="@drawable/ic_visibility_off"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/white" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Barra de força -->
            <LinearLayout
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="4dp"
                android:orientation="horizontal">
                <View android:id="@+id/forca1" android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1" android:layout_marginEnd="3dp" android:background="#33FFFFFF" />
                <View android:id="@+id/forca2" android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1" android:layout_marginEnd="3dp" android:background="#33FFFFFF" />
                <View android:id="@+id/forca3" android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1" android:layout_marginEnd="3dp" android:background="#33FFFFFF" />
                <View android:id="@+id/forca4" android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1" android:background="#33FFFFFF" />
            </LinearLayout>

            <TextView
                android:id="@+id/textForcaSenha"
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:textColor="@color/turquoise_light"
                android:textSize="11dp" />

            <TextView
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:text="Confirmar nova senha"
                android:textColor="@color/white"
                android:textSize="13dp" />

            <!-- Confirmar senha com olhinho -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/containerConfirmarSenha"
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:background="@drawable/text_box">

                <EditText
                    android:id="@+id/editConfirmarSenha"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:hint="Repita a senha"
                    android:inputType="textPassword"
                    android:padding="10dp"
                    android:textColor="@color/white"
                    android:textColorHint="#B3FFFFFF"
                    android:textSize="12dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/btnToggleConfirmarSenha"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageButton
                    android:id="@+id/btnToggleConfirmarSenha"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="4dp"
                    android:background="@null"
                    android:contentDescription="Mostrar confirmação de senha"
                    android:padding="6dp"
                    android:src="@drawable/ic_visibility_off"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/white" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <Button
                android:id="@+id/btnRedefinirSenha"
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:backgroundTint="@color/turquoise_light"
                android:text="REDEFINIR SENHA"
                android:textColor="@color/blue_navy"
                android:textSize="14dp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Passo 3: Sucesso -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingTop="80dp"
            android:paddingBottom="40dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓"
                android:textColor="@color/turquoise_light"
                android:textSize="52dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Senha redefinida!"
                android:textColor="@color/white"
                android:textSize="22dp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="32dp"
                android:alpha="0.75"
                android:text="Sua senha foi alterada com sucesso. Você já pode fazer login."
                android:textAlignment="center"
                android:textColor="@color/white"
                android:textSize="13dp" />

            <Button
                android:id="@+id/btnIrParaLogin"
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/turquoise_light"
                android:text="IR PARA O LOGIN"
                android:textColor="@color/blue_navy"
                android:textSize="14dp"
                android:textStyle="bold" />
        </LinearLayout>

    </ViewFlipper>
</androidx.constraintlayout.widget.ConstraintLayout>