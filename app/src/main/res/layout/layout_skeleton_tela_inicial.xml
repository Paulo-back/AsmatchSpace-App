<?xml version="1.0" encoding="utf-8"?>
<com.facebook.shimmer.ShimmerFrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/shimmer_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Card principal (AQI) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/shape_skeleton"
            android:layout_marginBottom="24dp">

            <!-- Linha de localização -->
            <View
                android:layout_width="120dp"
                android:layout_height="14dp"
                android:background="@drawable/shape_skeleton"
                android:layout_marginBottom="12dp"/>

            <!-- Número AQI grande -->
            <View
                android:layout_width="80dp"
                android:layout_height="64dp"
                android:background="@drawable/shape_skeleton"
                android:layout_marginBottom="12dp"/>

            <!-- Badge de status -->
            <View
                android:layout_width="80dp"
                android:layout_height="24dp"
                android:background="@drawable/shape_skeleton"
                android:layout_marginBottom="12dp"/>

            <!-- Linha de recomendação -->
            <View
                android:layout_width="200dp"
                android:layout_height="12dp"
                android:background="@drawable/shape_skeleton"/>

        </LinearLayout>

        <!-- Título "Detalhes dos Poluentes" -->
        <View
            android:layout_width="180dp"
            android:layout_height="18dp"
            android:background="@drawable/shape_skeleton"
            android:layout_marginBottom="12dp"/>

        <!-- Grid 2x2 de poluentes (3 linhas de 2 cards) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/shape_skeleton"
                android:layout_marginEnd="6dp">
                <View android:layout_width="40dp" android:layout_height="14dp"
                    android:background="@drawable/shape_skeleton" android:layout_marginBottom="8dp"/>
                <View android:layout_width="70dp" android:layout_height="10dp"
                    android:background="@drawable/shape_skeleton" android:layout_marginBottom="6dp"/>
                <View android:layout_width="55dp" android:layout_height="10dp"
                    android:background="@drawable/shape_skeleton"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/shape_skeleton"
                android:layout_marginStart="6dp">
                <View android:layout_width="40dp" android:layout_height="14dp"
                    android:background="@drawable/shape_skeleton" android:layout_marginBottom="8dp"/>
                <View android:layout_width="70dp" android:layout_height="10dp"
                    android:background="@drawable/shape_skeleton" android:layout_marginBottom="6dp"/>
                <View android:layout_width="55dp" android:layout_height="10dp"
                    android:background="@drawable/shape_skeleton"/>
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/shape_skeleton"
                android:layout_marginEnd="6dp">
                <View android:layout_width="40dp" android:layout_height="14dp"
                    android:background="@drawable/shape_skeleton" android:layout_marginBottom="8dp"/>
                <View android:layout_width="70dp" android:layout_height="10dp"
                    android:background="@drawable/shape_skeleton" android:layout_marginBottom="6dp"/>
                <View android:layout_width="55dp" android:layout_height="10dp"
                    android:background="@drawable/shape_skeleton"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/shape_skeleton"
                android:layout_marginStart="6dp">
                <View android:layout_width="40dp" android:layout_height="14dp"
                    android:background="@drawable/shape_skeleton" android:layout_marginBottom="8dp"/>
                <View android:layout_width="70dp" android:layout_height="10dp"
                    android:background="@drawable/shape_skeleton" android:layout_marginBottom="6dp"/>
                <View android:layout_width="55dp" android:layout_height="10dp"
                    android:background="@drawable/shape_skeleton"/>
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/shape_skeleton"
                android:layout_marginEnd="6dp">
                <View android:layout_width="40dp" android:layout_height="14dp"
                    android:background="@drawable/shape_skeleton" android:layout_marginBottom="8dp"/>
                <View android:layout_width="70dp" android:layout_height="10dp"
                    android:background="@drawable/shape_skeleton" android:layout_marginBottom="6dp"/>
                <View android:layout_width="55dp" android:layout_height="10dp"
                    android:background="@drawable/shape_skeleton"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/shape_skeleton"
                android:layout_marginStart="6dp">
                <View android:layout_width="40dp" android:layout_height="14dp"
                    android:background="@drawable/shape_skeleton" android:layout_marginBottom="8dp"/>
                <View android:layout_width="70dp" android:layout_height="10dp"
                    android:background="@drawable/shape_skeleton" android:layout_marginBottom="6dp"/>
                <View android:layout_width="55dp" android:layout_height="10dp"
                    android:background="@drawable/shape_skeleton"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.facebook.shimmer.ShimmerFrameLayout>