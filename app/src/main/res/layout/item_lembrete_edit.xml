<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <ImageView
        android:id="@+id/icon_delete_item"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:src="@drawable/icon_delete"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/icon_concluir_item"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_toStartOf="@id/icon_delete_item"
        android:layout_centerVertical="true"
        android:layout_marginEnd="12dp"
        android:src="@android:drawable/checkbox_off_background"
        android:contentDescription="Concluir lembrete"
        android:visibility="gone" />

    <!-- Ícone de recorrência — aparece à esquerda do texto -->
    <ImageView
        android:id="@+id/icon_recorrencia"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:src="@drawable/ic_schedule"
        android:visibility="gone" />

    <TextView
        android:id="@+id/text_lembrete"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/icon_recorrencia"
        android:layout_centerVertical="true"
        android:layout_toStartOf="@id/icon_concluir_item"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="8dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="08:00 - Usar Inalador"
        android:textColor="@color/white"
        android:textSize="16sp" />

</RelativeLayout>