<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Presentation.ActivityView.LembretesActivity">

    <ImageView
        android:id="@+id/corFundo"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/blue_navy"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/imgFundo"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.08"
        android:scaleType="centerCrop"
        android:src="@drawable/fundo"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Cabeçalho fixo — sempre visível -->
    <TextView
        android:id="@+id/lembretes_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Meus Lembretes"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <GridLayout
        android:id="@+id/grid_stats"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:columnCount="2"
        android:rowCount="2"
        app:layout_constraintTop_toBottomOf="@+id/lembretes_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <include android:id="@+id/stat_hoje"
            layout="@layout/card_lembrete_stat"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_columnWeight="1" android:layout_margin="4dp"/>

        <include android:id="@+id/stat_programados"
            layout="@layout/card_lembrete_stat"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_columnWeight="1" android:layout_margin="4dp"/>

        <include android:id="@+id/stat_todos"
            layout="@layout/card_lembrete_stat"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_columnWeight="1" android:layout_margin="4dp"/>

        <include android:id="@+id/stat_concluidos"
            layout="@layout/card_lembrete_stat"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_columnWeight="1" android:layout_margin="4dp"/>

    </GridLayout>

    <TextView
        android:id="@+id/minhas_listas_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginStart="16dp"
        android:text="Minhas Listas"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/grid_stats"
        app:layout_constraintBottom_toBottomOf="@+id/btnFiltrarPeriodo" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnFiltrarPeriodo"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="16dp"
        android:text="Últimos 7 dias"
        android:textSize="11sp"
        android:textColor="@color/turquoise_light"
        app:strokeColor="@color/turquoise_light"
        app:strokeWidth="1dp"
        app:backgroundTint="@android:color/transparent"
        app:cornerRadius="20dp"
        app:icon="@drawable/icon_edit"
        app:iconSize="13dp"
        app:iconTint="@color/turquoise_light"
        app:iconGravity="textStart"
        app:layout_constraintTop_toBottomOf="@+id/grid_stats"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="@+id/minhas_listas_title" />

    <!-- Skeleton — visível enquanto carrega, ancorado igual ao ScrollView real -->
    <ViewStub
        android:id="@+id/skeleton_stub"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:inflatedId="@+id/skeleton_container"
        android:layout="@layout/layout_skeleton_lembretes"
        android:layout_marginTop="8dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toBottomOf="@+id/minhas_listas_title"
        app:layout_constraintBottom_toTopOf="@+id/fab_novo_lembrete"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Lista real — começa GONE -->
    <ScrollView
        android:id="@+id/scroll_lista_lembretes"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@+id/minhas_listas_title"
        app:layout_constraintBottom_toTopOf="@+id/fab_novo_lembrete"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/container_lembretes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#474F6A99"
            android:padding="16dp"/>

    </ScrollView>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fab_editar_lembrete"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="Editar"
        android:textColor="@color/blue_navy"
        app:backgroundTint="@color/turquoise_light"
        app:icon="@drawable/icon_edit"
        app:iconTint="@color/blue_navy"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fab_novo_lembrete"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="Novo Lembrete"
        android:textColor="@color/blue_navy"
        app:backgroundTint="@color/turquoise_light"
        app:icon="@android:drawable/ic_input_add"
        app:iconTint="@color/blue_navy"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>